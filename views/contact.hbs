<!DOCTYPE html>
<html lang="en">
    <body>
        {{> main}}
        <div class="contact-container">
            <div class="contact-title">let's chat</div>
                <form class="contact-form" id="contact-form" action="/contact" method="POST">
                    <div class="contact-label">Your name (required)</div>
                    <input type="text" id="fullname" name="fullname" placeholder="Your name...">
                    <div class="contact-label">Your Email (required)</div>
                    <input type="text" id="email" name="email" placeholder="Your Email...">
                    <div class="contact-label">Subject</div>
                    <input type="text" id="subject" name="subject" placeholder="Subject...">
                    <div class="contact-label">Message</div>
                    <textarea rows="5" cols="50" id="note" name="note" placeholder="Your note..."></textarea>
                    <input type="submit" value="submit" onclick="hideContact()">
                </form>
                <div id="contact-thankyou">Good to be in touch! I'll get back to you shortly!</div>
                {{#if message}}
            <p id="contact-thankyou">{{message}}</p>
            {{/if}}
        </div>
        {{> footer}}
    </body>
    <script>
    // 1. Find the message element by its ID
    const message = document.getElementById('contact-thankyou');

    // 2. If the message exists, wait 3 seconds and then hide it
    if (message) {
        setTimeout(function() {
            message.style.display = 'none';
        }, 3000); // 3000 milliseconds = 3 seconds
    }
</script>
</html>